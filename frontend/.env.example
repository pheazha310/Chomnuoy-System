# =============================================================================
# CHOMNUOY FRONTEND ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Backend API base URL (Laravel server)
# Change to your production API URL when deploying
VITE_API_URL=http://127.0.0.1:8000/api
VITE_API_BASE_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
# Public app URL (used in share links, must be reachable by users)
# For local development: http://localhost:5173
# For production: https://your-domain.com
VITE_PUBLIC_APP_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Google OAuth 2.0 Client ID
# Get from: https://console.cloud.google.com/apis/credentials
# Leave empty to disable Google login
VITE_GOOGLE_CLIENT_ID=
# Set to true only after the current frontend origin has been added to
# Authorized JavaScript origins for the Google OAuth client.
VITE_ENABLE_GOOGLE_SIGN_IN=false

# Google OAuth redirect URL (must match backend GOOGLE_REDIRECT_URI)
VITE_GOOGLE_AUTH_URL=http://127.0.0.1:8000/api/auth/google/redirect

# Facebook OAuth 2.0 (optional)
# Get from: https://developers.facebook.com/apps
# Leave empty to disable Facebook login
VITE_FACEBOOK_CLIENT_ID=
VITE_FACEBOOK_AUTH_URL=http://127.0.0.1:8000/api/auth/facebook/redirect

