# Frontend API base URL
VITE_API_URL=http://127.0.0.1:8000/api
VITE_API_BASE_URL=http://127.0.0.1:8000

# Google Sign-In OAuth Web Client ID
VITE_GOOGLE_CLIENT_ID=

# Google Auth URL
VITE_GOOGLE_AUTH_URL=http://127.0.0.1:8000/api/auth/google/redirect

# Facebook Auth URL
VITE_FACEBOOK_AUTH_URL=http://127.0.0.1:8000/api/auth/facebook/redirect

# Public app URL used in share links (must be reachable by others)
# Example: https://your-domain.com
VITE_PUBLIC_APP_URL=

