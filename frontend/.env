# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Google OAuth 2.0 Client ID
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=529901988862-344m0simfhfr0bh0ufukptkmdnb0chpr.apps.googleusercontent.com
VITE_ENABLE_GOOGLE_SIGN_IN=true

# Google OAuth redirect URL (must match backend GOOGLE_REDIRECT_URI)
VITE_GOOGLE_AUTH_URL=https://chomnuoy-backend-1.onrender.com
    
