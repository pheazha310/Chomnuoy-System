# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Backend API base URL (Laravel server)
VITE_API_URL=https://chomnuoy-backend-1.onrender.com/api
VITE_API_BASE_URL=https://chomnuoy-backend-1.onrender.com

# -----------------------------------------------------------------------------
# App URLs
